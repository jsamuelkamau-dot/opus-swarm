# =============================================
# Opus Swarm — .gitignore
# Engineering Domain 1: Git / Version Control
# =============================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# --- Virtual Environment ---
.venv/
venv/
env/
ENV/

# --- Environment Variables (NEVER commit secrets) ---
.env
.env.local
.env.production
.env.staging
*.env

# --- Database ---
*.db
*.sqlite3
*.sqlite

# --- Logs ---
*.log
logs/
*.out

# --- OS Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# --- Docker ---
.docker/

# --- Node / Frontend ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
dist/
build/

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# --- MLflow / Experiment Tracking ---
mlruns/
mlartifacts/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Terraform ---
*.tfstate
*.tfstate.backup
.terraform/

# --- Sensitive / Keys ---
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/
